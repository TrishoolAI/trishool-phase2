{
  "version": "2.0.10",
  "gateway": {
    "mode": "local",
    "port": 18789,
    "bind": "lan",
    "auth": {
      "mode": "password"
    },
    "controlUi": {
      "dangerouslyAllowHostHeaderOriginFallback": true
    },
    "http": {
      "endpoints": {
        "chatCompletions": {
          "enabled": true,
          "stateless": true
        }
      }
    },
    "tools": {
      "allow": ["sessions_send"]
    },
    "tailscale": {
      "mode": "off"
    }
  },
  "agents": {
    "defaults": {
      "workspace": "/home/node/.openclaw/workspace",
      "model": {
        "primary": "chutes/Qwen/Qwen3-32B-TEE"
      },
      "models": {
        "chutes-default": { "alias": "chutes/Qwen/Qwen3-32B-TEE" },
        "openrouter-default": { "alias": "openrouter/qwen/qwen3-32b" }
      },
      "tools": {
        "allow": ["sessions_send", "trishool-eval-pii"],
        "deny": [
          "read",
          "write",
          "edit",
          "apply_patch",
          "exec",
          "process",
          "bash",
          "memory_search",
          "memory_get",
          "browser",
          "web_search",
          "web_fetch",
          "cron",
          "gateway"
        ]
      }
    }
  },
  "session": {
    "dmScope": "per-channel-peer"
  },
  "plugins": {
    "allow": ["memory-core", "guard-model", "trishool-eval-pii"],
    "slots": {
      "memory": "memory-core"
    },
    "entries": {
      "trishool-eval-pii": {
        "enabled": true
      },
      "guard-model": {
        "enabled": true,
        "config": {
          "enabled": true,
          "transport": "chutes_classify",
          "classifyUrl": "https://astroboi-halo-guard.chutes.ai/v1/classify",
          "classifyModel": "halo-guard",
          "queryMode": "text_extract",
          "logDecisions": true,
          "policy": {
            "parseMode": "json_or_safety_label",
            "evaluationFailureAction": "error",
            "unknownSafetyLabelAction": "allow",
            "allowLabels": ["safe", "controversial"],
            "blockLabels": ["unsafe"],
            "allowReasons": ["none", "politically sensitive topics", "copyright violation"],
            "blockReasons": ["violent", "non-violent illegal acts", "pii", "jailbreak"]
          },
          "input": {
            "enabled": true,
            "payloadMode": "latest_user_message",
            "queryMode": "text_extract"
          },
          "output": {
            "enabled": true,
            "payloadMode": "full_context",
            "queryMode": "text_extract"
          },
          "refusalText": "Blocked by guard model."
        }
      }
    }
  },
  "models": {
    "providers": {
      "chutes": {
        "baseUrl": "https://llm.chutes.ai/v1",
        "api": "openai-completions",
        "auth": "api-key",
        "models": [
          {
            "id": "Qwen/Qwen3.5-397B-A17B-TEE",
            "name": "Chutes Qwen3.5-397B-A17B-TEE",
            "reasoning": false,
            "input": ["text"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 256000,
            "maxTokens": 16384
          },
          {
            "id": "Qwen/Qwen3-235B-A22B-Instruct-2507-TEE",
