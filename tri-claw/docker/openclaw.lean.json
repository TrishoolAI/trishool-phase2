{
  "gateway": {
    "mode": "local",
    "port": 18789,
    "bind": "lan",
    "auth": {
      "mode": "password"
    },
    "controlUi": {
      "dangerouslyAllowHostHeaderOriginFallback": true
    },
    "http": {
      "endpoints": {
        "chatCompletions": {
          "enabled": true,
          "stateless": true
        }
      }
    },
    "tools": {
      "allow": ["sessions_send"]
    },
    "tailscale": {
      "mode": "off"
    }
  },
  "agents": {
    "defaults": {
      "workspace": "/home/node/.openclaw/workspace",
      "model": {
        "primary": "chutes/Qwen/Qwen3-32B-TEE",
        "fallbacks": [
          "chutes/Qwen/Qwen3.5-397B-A17B-TEE",
          "chutes/Qwen/Qwen3-235B-A22B-Instruct-2507-TEE"
        ]
      },
      "models": {
        "chutes-default": { "alias": "chutes/Qwen/Qwen3-32B-TEE" },
        "chutes-235b": { "alias": "chutes/Qwen/Qwen3-235B-A22B-Instruct-2507-TEE" },
        "chutes-fast": { "alias": "chutes/Qwen/Qwen3.5-397B-A17B-TEE" }
      }
    }
  },
  "session": {
    "dmScope": "per-channel-peer"
  },
  "plugins": {
    "allow": ["memory-core", "guard-model"],
    "slots": {
      "memory": "memory-core"
    },
    "entries": {
      "guard-model": {
        "enabled": false,
        "config": {
          "enabled": false,
          "model": "chutes/Qwen/Qwen3Guard-Gen-0.6B",
          "logDecisions": true,
          "policy": {
            "parseMode": "json_or_safety_label",
            "evaluationFailureAction": "allow",
            "unknownSafetyLabelAction": "allow",
            "allowLabels": ["safe", "controversial"],
            "blockLabels": ["unsafe"],
            "allowReasons": ["none", "politically sensitive topics", "copyright violation"],
            "blockReasons": ["violent", "non-violent illegal acts", "pii", "jailbreak"]
          },
          "input": {
            "enabled": true,
            "payloadMode": "latest_user_message"
          },
          "output": {
            "enabled": true
          },
          "refusalText": "Blocked by guard model."
        }
      }
    }
  },
  "models": {
    "providers": {
      "chutes": {
        "baseUrl": "https://llm.chutes.ai/v1",
        "api": "openai-completions",
        "auth": "api-key",
        "models": [
          {
            "id": "Qwen/Qwen3.5-397B-A17B-TEE",
            "name": "Chutes Qwen3.5-397B-A17B-TEE",
            "reasoning": false,
            "input": ["text"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 256000,
            "maxTokens": 16384
          },
          {
            "id": "Qwen/Qwen3-235B-A22B-Instruct-2507-TEE",
            "name": "Chutes Qwen3-235B-A22B-Instruct-2507-TEE",
            "reasoning": false,
            "input": ["text"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 256000,
            "maxTokens": 16384
          },
          {
            "id": "Qwen/Qwen3-32B-TEE",
            "name": "Chutes Qwen3-32B-TEE",
            "reasoning": false,
            "input": ["text"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 128000,
            "maxTokens": 16384
          },
          {
            "id": "openai/gpt-oss-20b-TEE",
            "name": "Chutes openai/gpt-oss-20b-TEE",
            "reasoning": false,
            "input": ["text"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 128000,
            "maxTokens": 16384
          },
          {
            "id": "chutesai/Mistral-Small-3.1-24B-Instruct-2503-TEE",
            "name": "Chutes Mistral-Small-3.1-24B-Instruct-2503-TEE",
            "reasoning": false,
            "input": ["text"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 128000,
            "maxTokens": 16384
          },
          {
            "id": "unsloth/gemma-3-27b-it",
            "name": "Chutes Gemma-3-27b-it",
            "reasoning": false,
            "input": ["text"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 128000,
            "maxTokens": 16384
          },
          {
            "id": "Qwen/Qwen3Guard-Gen-0.6B",
            "name": "Chutes Qwen3Guard-Gen-0.6B",
            "reasoning": false,
            "input": ["text"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 128000,
            "maxTokens": 16384
          }
        ]
      }
    }
  },
  "hooks": {
    "internal": {
      "enabled": true,
      "entries": {
        "boot-md": { "enabled": true },
        "bootstrap-extra-files": { "enabled": true }
      }
    }
  }
}
