# Repo-root env layout (all gitignored except *.example):
#   .env              — shared defaults (e.g. run-eval.js URLs below)
#   .env.tri-claw     — OpenClaw Docker / lean gateway secrets (see .env.tri-claw.example)
#   .env.tri-judge    — Judge API key for Docker (see .env.tri-judge.example)
#
# docker-up.sh creates empty files if missing; fill or copy from the *.example files.
#
# docker-up.sh --local only: host Halo guard (scripts/serve_halo_guard.py). TRISHOOL_SKIP_LOCAL_HALO_GUARD=1 skips even with --local.
# pip install -r scripts/requirements-halo-guard.txt in that Python env.
# HALO_GUARD_PYTHON=/path/to/.venv/bin/python
# HALO_GUARD_NO_TRUST_REMOTE_CODE=1
# HALO_GUARD_LOCAL_FILES_ONLY=1
# HALO_GUARD_BIND=0.0.0.0
# HALO_GUARD_PORT=8000
# HALO_GUARD_MODEL=astroware/Halo0.8B-guard-v1
# Halo guard uses classic Hub download by default (avoids stuck xet-read-token loops). To try Xet: HALO_GUARD_ENABLE_XET=1 in the shell when running docker-up.sh, or HF_HUB_DISABLE_XET=0.
# HALO_GUARD_QUIET_DOWNLOAD=1 — omit tqdm download progress lines in logs/halo-guard.log (default shows byte/shard progress under nohup).
# HALO_GUARD_VERBOSE_HTTP=1 — log every Hub httpx HEAD/GET line again (default is quieter: phase lines + tqdm only).
#
# run-eval.js: URLs in .env
OPENCLAW_URL=http://localhost:18789
OPENCLAW_GATEWAY_PASSWORD=
# or OPENCLAW_GATEWAY_TOKEN=

JUDGE_URL=http://localhost:8080

# Chutes API key: sent per-request (X-Chutes-Api-Key); often not in gateway env
CHUTES_API_KEY=
# OpenRouter key: tri-check / validator send as X-OpenRouter-Api-Key to OpenClaw when set
OPENROUTER_API_KEY=
# tri-check / validator → tri-judge only: chutes (default) or openrouter — match judge.lean.json judge.provider
JUDGE_LLM_PROVIDER=chutes #openrouter

# PM2 repo-auto-updater: GitHub API (higher rate limit; needed for private repos)
# Fine-grained or classic PAT with repo read access to the monitored repo
GITHUB_TOKEN=

# PM2 repo-auto-updater / optional: absolute path to venv Python if not on PATH when PM2 runs
# PYTHON=/path/to/venv/bin/python
