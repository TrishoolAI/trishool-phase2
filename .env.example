# Repo-root env layout (all gitignored except *.example):
#   .env              — shared defaults (e.g. run-eval.js URLs below)
#   .env.tri-claw     — OpenClaw Docker / lean gateway secrets (see .env.tri-claw.example)
#   .env.tri-judge    — Judge API key for Docker (see .env.tri-judge.example)
#
# docker-up.sh creates empty files if missing; fill or copy from the *.example files.
#
# run-eval.js: URLs in .env
OPENCLAW_URL=http://localhost:18789
OPENCLAW_GATEWAY_PASSWORD=
# or OPENCLAW_GATEWAY_TOKEN=

JUDGE_URL=http://localhost:8080

# Chutes API key: sent per-request (X-Chutes-Api-Key); often not in gateway env
CHUTES_API_KEY=
