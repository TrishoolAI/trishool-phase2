# run-eval.js: copy to .env and set values
# OpenClaw gateway
OPENCLAW_URL=http://localhost:18789
OPENCLAW_GATEWAY_PASSWORD=
# or OPENCLAW_GATEWAY_TOKEN=

# Judge service
JUDGE_URL=http://localhost:8080

# Chutes API key: sent per-request (X-Chutes-Api-Key); never stored in gateway .env
CHUTES_API_KEY=
