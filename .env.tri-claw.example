# Stable project name so Compose never reuses old container IDs after Docker data-root move
COMPOSE_PROJECT_NAME=tri-claw
OPENCLAW_CONFIG_DIR=~/.openclaw
OPENCLAW_WORKSPACE_DIR=~/.openclaw/workspace
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_IMAGE=openclaw:lean
OPENCLAW_EXTRA_MOUNTS=
OPENCLAW_HOME_VOLUME=
OPENCLAW_DOCKER_APT_PACKAGES=
OPENCLAW_CHUTES_TOKEN=
# Chutes base URL and model fallback chain are now defined in tri-claw/docker/openclaw.lean.json.
OPENCLAW_GATEWAY_PASSWORD=

