# Stable project name so Compose never reuses old container IDs after Docker data-root move
COMPOSE_PROJECT_NAME=tri-claw
OPENCLAW_CONFIG_DIR=~/.openclaw
OPENCLAW_WORKSPACE_DIR=~/.openclaw/workspace
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_IMAGE=openclaw:lean
OPENCLAW_EXTRA_MOUNTS=
OPENCLAW_HOME_VOLUME=
OPENCLAW_DOCKER_APT_PACKAGES=
OPENCLAW_CHUTES_TOKEN=
CHUTES_BASE_URL="https://llm.chutes.ai/v1"
CHUTES_DEFAULT_MODEL_ID="Qwen/Qwen3-Next-80B-A3B-Instruct"
CHUTES_DEFAULT_MODEL_REF="chutes/Qwen/Qwen3-Next-80B-A3B-Instruct"
CHUTES_FAST_MODEL_ID="Qwen/Qwen3-Next-80B-A3B-Instruct"
CHUTES_FAST_MODEL_REF="chutes/Qwen/Qwen3-Next-80B-A3B-Instruct"
# CHUTES_DEFAULT_MODEL_ID="chutesai/Mistral-Small-3.2-24B-Instruct-2506"
# CHUTES_DEFAULT_MODEL_REF="chutes/chutesai/Mistral-Small-3.2-24B-Instruct-2506"
# CHUTES_FAST_MODEL_ID="chutesai/Mistral-Small-3.2-24B-Instruct-2506"
# CHUTES_FAST_MODEL_REF="chutes/chutesai/Mistral-Small-3.2-24B-Instruct-2506"
OPENCLAW_GATEWAY_PASSWORD=

