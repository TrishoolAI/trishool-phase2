# tri-check loads this file from tri-check/.env (copy from here), then repo-root .env (non-overriding).
#
# Prereqs (repo root): Docker installed; fill ../.env.tri-claw + ../.env.tri-judge; run bash docker-up.sh
# OPENCLAW_GATEWAY_PASSWORD here must match ../.env.tri-claw (same gateway the Docker stack uses).

# OpenClaw gateway base URL (no trailing slash required)
OPENCLAW_URL=http://localhost:18789

# OpenClaw auth (use one)
OPENCLAW_GATEWAY_PASSWORD=
# OPENCLAW_GATEWAY_TOKEN=

# Judge API base URL
JUDGE_URL=http://localhost:8080

# Optional: forwarded on requests as X-Chutes-Api-Key; also Bearer for guard-probe Halo classify
CHUTES_API_KEY=
# Optional: forwarded as X-OpenRouter-Api-Key to OpenClaw when set (use with OPENROUTER models)
OPENROUTER_API_KEY=
# Which key tri-check sends to tri-judge only: chutes (default) or openrouter — must match judge.lean.json judge.provider
JUDGE_LLM_PROVIDER=chutes

# Optional overrides for `pnpm guard-probe` (direct Halo mode, Chutes)
# HALO_CLASSIFY_URL=https://astroboi-halo-guard.chutes.ai/v1/classify
# HALO_CLASSIFY_MODEL=halo-guard

# Local Halo classify (scripts/serve_halo_guard.py). Used by `pnpm guard-probe -- --local` and `pnpm eval -- --local`. Start via `bash docker-up.sh --local` or run the Python script manually.
# (OpenClaw must be rebuilt from this repo so the gateway honors X-Openclaw-Guard-* headers).
# If the gateway runs in Docker, use host reachability, e.g.:
# HALO_LOCAL_CLASSIFY_URL=http://host.docker.internal:8000/v1/classify
# HALO_LOCAL_CLASSIFY_URL=http://127.0.0.1:8000/v1/classify
# HALO_LOCAL_CLASSIFY_MODEL=astroware/Halo0.8B-guard-v1

# Set to 1 to log full Chutes key (avoid in shared logs)
# TRI_CHECK_REVEAL_CHUTES_KEY=

# Optional: merge Q7–Q12 judge secrets / expected_unsafe from generated fixtures (same as validator)
# Default: ../tri-claw/docker/eval-fixtures/ground-truth.json if present
# TRISHOOL_EVAL_GROUND_TRUTH=
# TRI_CHECK_NO_GROUND_TRUTH=1

# Set to 1 to redact ground-truth fixture strings in CLI output. Default off so the judge receives verbatim
# model text and jailbreak checks match leaked secrets (CHUTES / gateway tokens still redacted in logs).
# TRI_CHECK_REDACT_FIXTURE_OUTPUT=
